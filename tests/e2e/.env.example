# Required: neutree server connection
NEUTREE_SERVER_URL=https://your-neutree-server.example.com
NEUTREE_API_KEY=sk_your_api_key

# Required: model registry URL
E2E_MODEL_REGISTRY_URL=nfs://nfs-server:/path/to/models

# Optional: override resource names
# E2E_MODEL_REGISTRY=e2e-registry-<random>
# E2E_WORKSPACE=default

# Optional: ExternalEndpoint tests - hostname for mock upstream reachable from Kong container
# Defaults to "host.docker.internal" (macOS Docker Desktop).
# For Linux, set to the host's IP reachable from Docker network.
# E2E_MOCK_UPSTREAM_HOST=host.docker.internal

# Required for cluster tests: image registry
# E2E_IMAGE_REGISTRY_URL=https://192.168.22.100
# E2E_IMAGE_REGISTRY_REPO=neutree-test
# E2E_IMAGE_REGISTRY=e2e-image-registry-<random>

# Optional: SSH cluster tests (skip if not set)
# E2E_SSH_HEAD_IP=10.0.0.1
# E2E_SSH_WORKER_IPS=10.0.0.2,10.0.0.3
# E2E_SSH_USER=root
# E2E_SSH_PRIVATE_KEY=<base64-encoded-private-key>

# Optional: K8s cluster tests (skip if not set)
# E2E_KUBECONFIG=<base64-encoded-kubeconfig>

# Optional: Endpoint tests - model configuration
# E2E_CLUSTER_NAME=my-cluster
# E2E_ENGINE_NAME=vllm
# E2E_ENGINE_VERSION_A=v0.8.5
# E2E_ENGINE_VERSION_B=v0.11.2
# E2E_MODEL_NAME=my-chat-model
# E2E_MODEL_VERSION=latest
# E2E_MODEL_TASK=text-generation
# E2E_ACCELERATOR_TYPE=nvidia_gpu
# E2E_ACCELERATOR_PRODUCT=
# E2E_ENDPOINT_ENGINE_ARGS=dtype=half
# E2E_ENDPOINT_TIMEOUT=10m

# Optional: Embedding inference tests (skip if not set)
# E2E_EMBEDDING_MODEL_NAME=BAAI/bge-base-en-v1.5
# E2E_EMBEDDING_MODEL_VERSION=latest

# Optional: Rerank inference tests (skip if not set)
# E2E_RERANK_MODEL_NAME=BAAI/bge-reranker-base
# E2E_RERANK_MODEL_VERSION=latest

# Optional: TestRail reporting
# TESTRAIL_RUN_ID=123
# TESTRAIL_URL=http://testrail.example.com
# TESTRAIL_USER=testrail-dev@example.com
# TESTRAIL_PASSWORD=example
