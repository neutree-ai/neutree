# Required: neutree server connection
NEUTREE_SERVER_URL=https://your-neutree-server.example.com
NEUTREE_API_KEY=sk_your_api_key

# Optional: path to profile YAML (all test config lives here now)
# See profile.yaml.example for available fields.
# E2E_PROFILE_PATH=./tests/e2e/profile.yaml

# Optional: TestRail run ID (overrides profile value if set)
# TESTRAIL_RUN_ID=123
