# E2E test profile
# Copy to profile.yaml and fill in values, then set E2E_PROFILE_PATH=./tests/e2e/profile.yaml

auth:
  email: admin@neutree.local
  password: "111111"

testrail:
  run_id: ""
  url: ""
  user: ""
  password: ""

ssh_nodes:
  - host: 192.168.1.100
    user: root
    key_file: ~/.ssh/id_rsa

kubernetes:
  kubeconfig: ~/.kube/config
  router_access_mode: LoadBalancer

image_registry:
  url: ""
  repository: ""
  username: ""
  password: ""

model_registry:
  type: hugging-face
  url: https://huggingface.co
  credentials: ""

workspace: default

cluster:
  version: v1.0.1
  # old_version: for upgrade tests — the version to create before upgrading to cluster.version
  # If not set, upgrade tests are skipped.
  old_version: ""

engine:
  name: vllm
  version: v0.11.2
  # old_version: for multi-version isolation tests only
  old_version: v0.8.5

model:
  name: test-model
  version: "1.0"
  file: model.safetensors
  task: text-generation

# Optional: embedding inference tests (skip if not configured)
embedding_model:
  name: ""
  version: ""

# Optional: rerank inference tests (skip if not configured)
rerank_model:
  name: ""
  version: ""

endpoint:
  # accelerator_type and accelerator_product are auto-detected from cluster status
  engine_args: "dtype=half"
  timeout: "10m"

mock_upstream_host: host.docker.internal

# Control plane deploy/cleanup tests
control_plane:
  deploy_mode: docker-compose    # docker-compose | kubernetes
  api_port: 3000
  version: ""                    # CP version for --version flag (e.g. v1.0.1)
  cli_url: ""                    # URL to download CLI binary (enterprise); if empty, compile from source
  chart_url: ""                  # URL to download helm chart .tgz (enterprise); if empty, use local chart
  mirror_registry: ""            # mirror registry for --mirror-registry (e.g. registry.example.com:5000)
  registry_project: ""           # registry project for --registry-project (e.g. neutree-ai)
  offline_image_url: ""          # URL to offline image archive (leave empty to skip offline tests)

  # docker-compose mode (leave host empty to skip VM deploy tests)
  host: ""
  ssh_user: root
  ssh_key: ~/.ssh/id_rsa
  compose_dir: /home/neutree/    # neutree-cli working directory on VM

  # kubernetes mode (leave kubeconfig empty to skip K8s deploy tests)
  kubeconfig: ""                 # path to kubeconfig for CP K8s cluster
  k8s_namespace: neutree-e2e    # helm install namespace

  # upgrade tests (leave old_version empty to skip)
  old_version: ""                # old CP version (e.g. v1.0.0) for upgrade tests
  old_cli_url: ""                # URL to download old version neutree-cli binary

model_cache:
  host_path: /data/models
  nfs_server: ""
  nfs_path: ""
  pvc_storage_class: ""
