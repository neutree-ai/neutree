FROM vllm/vllm-openai:v0.18.1

RUN pip install --upgrade pip && \
    pip install --upgrade transformers tokenizers && \
    pip install huggingface-hub sentencepiece

# Fix qwen3_5 config list-vs-set issue for transformers 5.x
# Line 71-74: kwargs["ignore_keys_at_rope_validation"] = [...] -> {...}
RUN sed -i '/ignore_keys_at_rope_validation/,/^        \]/{s/= \[/= {/; s/^        \]$/        }/}' \
    /usr/local/lib/python3.12/dist-packages/vllm/transformers_utils/configs/qwen3_5.py
