ARG RAY_COMMIT
ARG COMMON_WORKDIR=/app
ARG RAY_REPO
ARG ENGINE_BASE_IMAGE=vllm/vllm-openai:v0.11.2
ARG ENGINE_VERSION_DIR=v0_11_2
ARG RAY_BUILD_BASE_IMAGE="quay.io/pypa/manylinux2014_x86_64:2024-07-02-9ac04ee"

# --- Ray source fetch ---
FROM alpine/git:v2.47.2 AS ray_fetch
ARG RAY_REPO
ARG RAY_COMMIT
ARG COMMON_WORKDIR
WORKDIR ${COMMON_WORKDIR}
RUN git clone ${RAY_REPO} \
	    && cd ray \
	    && git checkout ${RAY_COMMIT}

# --- Ray wheel build ---
FROM ${RAY_BUILD_BASE_IMAGE} AS build_ray
ARG COMMON_WORKDIR
ARG RAY_COMMIT
ENV BUILDKITE_COMMIT=${RAY_COMMIT}
ENV TRAVIS_COMMIT=${BUILDKITE_COMMIT}
ENV BUILD_ONE_PYTHON_ONLY=py312
ENV RAY_DISABLE_EXTRA_CPP=1
WORKDIR /ray
COPY --from=ray_fetch ${COMMON_WORKDIR}/ray /ray
RUN /ray/python/build-wheel-manylinux2014.sh

# --- Engine image ---
FROM ${ENGINE_BASE_IMAGE}

ENV HOME=/home/ray
WORKDIR ${HOME}

# Pin the correct nixl CUDA-major variant matching the vLLM base image's
# CUDA runtime. The vllm-openai base preinstalls nixl-cuXX; we force-
# reinstall the right one so version drift across base-image updates can't
# silently leave a stale variant in site-packages.
#
# Target CUDA major resolution (first non-empty wins):
#   1. TARGET_CUDA build arg (explicit override — non-standard forks / patches)
#   2. vLLM version rule applied to ENGINE_VERSION_DIR (e.g. "v0_17_1" → "0.17.1"):
#        < 0.20.0  → vLLM ships CUDA 12.9 → cuda_target=12
#        >= 0.20.0 → vLLM ships CUDA 13.0 → cuda_target=13
#      (vLLM upstream switched default CUDA from 12.9 to 13.0 at 0.20.0.
#       Update this threshold when upstream changes again.)
#   3. cuXX suffix in ENGINE_BASE_IMAGE tag (legacy / forced fallback)
#   4. no-op (non-semver versions like "gemma4" with no cu suffix)
#
# NIXL_VERSION (optional) is concatenated after the package name to pin a
# specific nixl release, e.g. NIXL_VERSION='<0.10.0' or '==0.5.0'. Empty
# means "latest available for this cuXX".
ARG ENGINE_BASE_IMAGE
ARG ENGINE_VERSION_DIR
ARG TARGET_CUDA=""
ARG NIXL_VERSION=""
RUN cuda_target="${TARGET_CUDA}"; \
    if [ -z "$cuda_target" ] && [ -n "${ENGINE_VERSION_DIR}" ]; then \
        ver=$(printf '%s' "${ENGINE_VERSION_DIR}" | sed 's/^v//;s/_/./g'); \
        if echo "$ver" | grep -Eq '^[0-9]+\.[0-9]+'; then \
            lowest=$(printf '%s\n%s' "$ver" "0.20.0" | sort -V | head -1); \
            if [ "$lowest" = "$ver" ] && [ "$ver" != "0.20.0" ]; then \
                cuda_target=12; \
            else \
                cuda_target=13; \
            fi; \
            echo "[nixl-reconcile] vLLM $ver → cuda_target=$cuda_target (threshold 0.20.0)"; \
        fi; \
    fi; \
    if [ -z "$cuda_target" ]; then \
        cuda_target=$(printf '%s' "${ENGINE_BASE_IMAGE}" | grep -oE 'cu[0-9]+' | head -1 | sed 's/^cu//'); \
    fi; \
    if [ -n "$cuda_target" ]; then \
        echo "[nixl-reconcile] force-reinstall nixl-cu${cuda_target}${NIXL_VERSION}"; \
        uv pip install --system --force-reinstall --no-deps "nixl-cu${cuda_target}${NIXL_VERSION}"; \
    else \
        echo "[nixl-reconcile] could not determine target CUDA; leaving nixl as-is"; \
    fi

# Install Ray neutree fork (same version as cluster image)
RUN --mount=type=bind,from=build_ray,src=/ray,target=/install \
    cd /install \
    && whl=$(ls .whl/*.whl) \
    && uv pip install --system "${whl}[serve,cgraph]"

# Install common serve-layer dependencies
RUN --mount=type=bind,src=requirements,target=requirements \
    uv pip install --system -r requirements/common.txt

# Copy Neutree serve layer code (shared + specified engine version only)
ARG ENGINE_VERSION_DIR
COPY serve/_metrics ./serve/_metrics
COPY serve/_replica_scheduler ./serve/_replica_scheduler
COPY serve/_utils ./serve/_utils
COPY serve/_ingress_router ./serve/_ingress_router
COPY serve/vllm/${ENGINE_VERSION_DIR} ./serve/vllm/${ENGINE_VERSION_DIR}
# Copy downloader sources only; do NOT `pip install` downloader/requirements.txt.
# Its huggingface-hub<1.0 pin would downgrade the newer huggingface_hub already
# shipped by the vllm base image, breaking newer transformers releases.
COPY downloader ./downloader

# Ensure "python" is in PATH (some base images only provide "python3")
RUN ln -sf $(which python3) /usr/bin/python 2>/dev/null || true

# Reset ENTRYPOINT from base image (vllm/vllm-openai sets "vllm serve")
# so that Ray can execute its own commands in this container.
ENTRYPOINT []
CMD ["/bin/bash"]
