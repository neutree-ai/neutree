# Phase 0 Demo — vLLM PD same-host engine image.
#
# Builds on the existing Dockerfile.engine-vllm and additionally pins NIXL +
# UCX so the demo can exercise NIXL cuda_ipc zero-copy KV transfer between
# the prefill and decode actors that live on the same host.
#
# Build args:
#   ENGINE_BASE_IMAGE=vllm/vllm-openai:v0.17.1   # PD same-host requires >= v0.17.1
#   ENGINE_VERSION_DIR=v0_17_1
#
# Build invocation (example):
#   docker build \
#     --build-arg ENGINE_BASE_IMAGE=vllm/vllm-openai:v0.17.1 \
#     --build-arg ENGINE_VERSION_DIR=v0_17_1 \
#     --build-arg RAY_REPO=https://github.com/neutree-ai/ray \
#     --build-arg RAY_COMMIT=<commit> \
#     -f Dockerfile.engine-vllm-pd \
#     -t neutree/engine-vllm:v0.17.1-pd \
#     cluster-image-builder/
#
# MVP (PR-14) collapses this into Dockerfile.engine-vllm once the PD path is
# stable; Demo keeps it as a sibling Dockerfile to avoid disturbing the
# monolithic release pipeline.

ARG RAY_COMMIT
ARG COMMON_WORKDIR=/app
ARG RAY_REPO
ARG ENGINE_BASE_IMAGE=vllm/vllm-openai:v0.17.1
ARG ENGINE_VERSION_DIR=v0_17_1
ARG RAY_BUILD_BASE_IMAGE="quay.io/pypa/manylinux2014_x86_64:2024-07-02-9ac04ee"

# --- Ray source fetch ---
FROM alpine/git:v2.47.2 AS ray_fetch
ARG RAY_REPO
ARG RAY_COMMIT
ARG COMMON_WORKDIR
WORKDIR ${COMMON_WORKDIR}
RUN git clone ${RAY_REPO} \
        && cd ray \
        && git checkout ${RAY_COMMIT}

# --- Ray wheel build ---
FROM ${RAY_BUILD_BASE_IMAGE} AS build_ray
ARG COMMON_WORKDIR
ARG RAY_COMMIT
ENV BUILDKITE_COMMIT=${RAY_COMMIT}
ENV TRAVIS_COMMIT=${BUILDKITE_COMMIT}
ENV BUILD_ONE_PYTHON_ONLY=py312
ENV RAY_DISABLE_EXTRA_CPP=1
WORKDIR /ray
COPY --from=ray_fetch ${COMMON_WORKDIR}/ray /ray
RUN /ray/python/build-wheel-manylinux2014.sh

# --- Engine image ---
FROM ${ENGINE_BASE_IMAGE}

ENV HOME=/home/ray
WORKDIR ${HOME}

# Install Ray neutree fork (same version as cluster image)
RUN --mount=type=bind,from=build_ray,src=/ray,target=/install \
    cd /install \
    && whl=$(ls .whl/*.whl) \
    && uv pip install --system "${whl}[serve,cgraph]"

# Install common serve-layer dependencies
RUN --mount=type=bind,src=requirements,target=requirements \
    uv pip install --system -r requirements/common.txt

# ── PD same-host runtime ────────────────────────────────────────────────────
# NIXL + UCX for cuda_ipc zero-copy KV transfer between prefill and decode
# actors collocated on the same host. Pin nixl<0.10.0 per Phase 1 same-host
# KV connector deep-dive (project memory: project-pd-same-host-phase1, section
# "same-host KV connector deep dive").
RUN uv pip install --system "nixl<0.10.0"

# UCX_TLS allowlist: collapse to same-host transports + cuda_copy + cuda_ipc.
# This avoids the UCX rc/tcp fallback that swallows NIXL handshake errors on
# multi-NIC hosts (vLLM Bug #35799). Override at deploy-time via env if a
# cross-host PD variant ever runs from this image (it won't in Phase 1).
ENV UCX_TLS=self,sm,cuda_copy,cuda_ipc

# Fabric Manager socket — mount /var/run/nvidia-fabricmanager at runtime
# (Pod spec or docker -v) so NIXL can negotiate NVSwitch routing on H100 SXM.
VOLUME /var/run/nvidia-fabricmanager
# ─────────────────────────────────────────────────────────────────────────────

# Copy Neutree serve layer code (shared + specified engine version + PD ingress)
ARG ENGINE_VERSION_DIR
COPY serve/_metrics ./serve/_metrics
COPY serve/_replica_scheduler ./serve/_replica_scheduler
COPY serve/_utils ./serve/_utils
COPY serve/_ingress_router ./serve/_ingress_router
COPY serve/vllm/${ENGINE_VERSION_DIR} ./serve/vllm/${ENGINE_VERSION_DIR}
# Copy downloader sources only; do NOT `pip install` downloader/requirements.txt.
# Its huggingface-hub<1.0 pin would downgrade the newer huggingface_hub already
# shipped by the vllm base image, breaking newer transformers releases.
COPY downloader ./downloader

# Ensure "python" is in PATH (some base images only provide "python3")
RUN ln -sf $(which python3) /usr/bin/python 2>/dev/null || true

# Reset ENTRYPOINT from base image (vllm/vllm-openai sets "vllm serve")
# so that Ray can execute its own commands in this container.
ENTRYPOINT []
CMD ["/bin/bash"]
