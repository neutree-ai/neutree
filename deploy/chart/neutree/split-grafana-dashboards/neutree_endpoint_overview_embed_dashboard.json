        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$Datasource"
          },
          "editorMode": "code",
          "expr": "max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint=~\"$Endpoint\"}[30m])) * on (node, gpu_uuid) group_left(architecture, cuda_capability, driver_version, cuda_driver_version, nvlink, nvswitch, pcie_bus_id, pcie_generation, pcie_width, numa_node) max by (node, gpu_uuid, architecture, cuda_capability, driver_version, cuda_driver_version, nvlink, nvswitch, pcie_bus_id, pcie_generation, pcie_width, numa_node) (neutree_node_gpu_hardware_info{neutree_cluster=~\"$Cluster\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "hardware",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$Datasource"
          },
          "editorMode": "code",
          "expr": "max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint=~\"$Endpoint\"}[30m])) * on (node, gpu_uuid) group_left() max by (node, gpu_uuid) (last_over_time(neutree_gpu_utilization_ratio{neutree_cluster=~\"$Cluster\"}[30m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "gpu util",
          "range": false,
          "refId": "C"
