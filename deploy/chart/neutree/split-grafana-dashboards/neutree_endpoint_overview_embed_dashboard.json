          "editorMode": "code",
          "expr": "max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint=~\"$Endpoint\"}[30m]))",
