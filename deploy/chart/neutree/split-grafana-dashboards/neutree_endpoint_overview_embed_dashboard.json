      "targets": [
        {
          "expr": "max by (node, gpu_uuid) (last_over_time(neutree_gpu_utilization_ratio{neutree_cluster=~\"$Cluster\"}[30m])) * on (node, gpu_uuid) group_left(replica, gpu_index) max by (node, gpu_uuid, replica, gpu_index) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint=~\"$Endpoint\"}[30m]))",
