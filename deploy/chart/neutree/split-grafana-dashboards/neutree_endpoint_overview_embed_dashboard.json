        {
          "expr": "max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint=~\"$Endpoint\"}[30m])) * on (node, gpu_uuid) group_left() (sum by (node, gpu_uuid) (rate(neutree_gpu_pcie_tx_bytes_total{neutree_cluster=~\"$Cluster\"}[$__rate_interval])) + sum by (node, gpu_uuid) (rate(neutree_gpu_pcie_rx_bytes_total{neutree_cluster=~\"$Cluster\"}[$__rate_interval])))",
          "refId": "D",
