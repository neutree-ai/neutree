        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 3,
      "targets": [
        {
          "expr": "(max by (node, gpu_uuid) (last_over_time(neutree_gpu_memory_used_bytes{neutree_cluster=~\"$Cluster\"}[30m])) / clamp_min(max by (node, gpu_uuid) (last_over_time(neutree_gpu_memory_total_bytes{neutree_cluster=~\"$Cluster\"}[30m])), 1)) * on (node, gpu_uuid) group_left(replica, gpu_index) max by (node, gpu_uuid, replica, gpu_index) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint=~\"$Endpoint\"}[30m]))",
