      "targets": [
        {
          "expr": "sum(max by (node, gpu_uuid) (last_over_time(neutree_gpu_memory_used_bytes{neutree_cluster=~\"$Cluster\"}[30m])) * on (node, gpu_uuid) group_left() max by (node, gpu_uuid) (last_over_time(neutree_node_gpu_allocation{neutree_cluster=~\"$Cluster\",endpoint=~\"$Endpoint\"}[30m])))",
