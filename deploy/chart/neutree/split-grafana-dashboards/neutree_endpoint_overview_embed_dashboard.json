          "editorMode": "code",
          "expr": "max by (endpoint, replica, node, gpu_uuid, model_replica, model_name) ((label_join((max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint=~\"$Endpoint\"}[30m])) * on (replica) group_left(model_name) (max by (replica, model_name) (last_over_time(vllm:num_requests_running{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m]) or last_over_time(vllm:request_success_total{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m]) or last_over_time(vllm:engine_sleep_state{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m]) or last_over_time(sglang_num_running_reqs{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m]) or last_over_time(sglang_num_requests_total{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m])) or label_replace(max by (replica, served_model_name) (last_over_time(sglang_num_running_reqs{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",served_model_name=~\".+\"}[30m]) or last_over_time(sglang_num_requests_total{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",served_model_name=~\".+\"}[30m])), \"model_name\", \"$1\", \"served_model_name\", \"(.*)\"))), \"model_replica\", \" / \", \"model_name\", \"replica\")) or (label_join(label_set(max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint=~\"$Endpoint\"}[30m])), \"model_name\", \"-\"), \"model_replica\", \" / \", \"model_name\", \"replica\") unless on (replica) (max by (replica, model_name) (last_over_time(vllm:num_requests_running{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m]) or last_over_time(vllm:request_success_total{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m]) or last_over_time(vllm:engine_sleep_state{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m]) or last_over_time(sglang_num_running_reqs{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m]) or last_over_time(sglang_num_requests_total{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",model_name=~\".+\"}[30m])) or label_replace(max by (replica, served_model_name) (last_over_time(sglang_num_running_reqs{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",served_model_name=~\".+\"}[30m]) or last_over_time(sglang_num_requests_total{neutree_cluster=~\"$Cluster\",application=~\".*$Endpoint.*\",served_model_name=~\".+\"}[30m])), \"model_name\", \"$1\", \"served_model_name\", \"(.*)\"))))",
          "format": "table",
          "instant": true,
          "legendFormat": "model",
          "range": false,
          "refId": "F"
        }
      ],
