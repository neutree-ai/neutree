{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "${datasource}",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "count(count by (node) (last_over_time(neutree_node_ready{neutree_cluster=~\"$Cluster\"}[30m])))",
          "refId": "A"
        }
      ],
      "title": "Nodes",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 5,
        "y": 0
      },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(last_over_time(neutree_node_gpu_total{neutree_cluster=~\"$Cluster\"}[30m]))",
          "refId": "A"
        }
      ],
      "title": "Total GPUs",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 10,
        "y": 0
      },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(last_over_time(neutree_node_gpu_free{neutree_cluster=~\"$Cluster\"}[30m]))",
          "refId": "A"
        }
      ],
      "title": "Free GPUs",
      "type": "stat"
    },
    {
      "datasource": "${datasource}",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 15,
        "y": 0
      },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "avg(last_over_time(neutree_gpu_utilization_ratio{neutree_cluster=~\"$Cluster\"}[30m]))",
          "refId": "A"
        }
      ],
      "title": "GPU avg",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "datasource": "${datasource}",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "id": 5,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(last_over_time(neutree_gpu_memory_used_bytes{neutree_cluster=~\"$Cluster\"}[30m])) / clamp_min(sum(last_over_time(neutree_gpu_memory_total_bytes{neutree_cluster=~\"$Cluster\"}[30m])), 1)",
          "refId": "A"
        }
      ],
      "title": "VRAM avg",
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 7,
      "targets": [
        {
          "expr": "1 - avg(rate(neutree_node_cpu_seconds_total{neutree_cluster=~\"$Cluster\",mode=\"idle\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "CPU avg"
        },
        {
          "expr": "sum(neutree_node_memory_used_bytes{neutree_cluster=~\"$Cluster\"}) / clamp_min(sum(neutree_node_memory_total_bytes{neutree_cluster=~\"$Cluster\"}), 1)",
          "refId": "B",
          "legendFormat": "Memory avg"
        },
        {
          "expr": "avg(neutree_gpu_utilization_ratio{neutree_cluster=~\"$Cluster\"})",
          "refId": "C",
          "legendFormat": "GPU avg"
        },
        {
          "expr": "sum(neutree_gpu_memory_used_bytes{neutree_cluster=~\"$Cluster\"}) / clamp_min(sum(neutree_gpu_memory_total_bytes{neutree_cluster=~\"$Cluster\"}), 1)",
          "refId": "D",
          "legendFormat": "VRAM avg"
        }
      ],
      "title": "Utilization trend",
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "datasource": "${datasource}",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 8,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$Datasource"
          },
          "editorMode": "code",
          "expr": "max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint!=\"-\",replica!=\"-\"}[30m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "allocation info",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$Datasource"
          },
          "editorMode": "code",
          "expr": "max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint!=\"-\",replica!=\"-\"}[30m])) * on (node, gpu_uuid) group_left(architecture, cuda_capability, driver_version, cuda_driver_version, nvlink, nvswitch, pcie_bus_id, pcie_generation, pcie_width, numa_node) max by (node, gpu_uuid, architecture, cuda_capability, driver_version, cuda_driver_version, nvlink, nvswitch, pcie_bus_id, pcie_generation, pcie_width, numa_node) (neutree_node_gpu_hardware_info{neutree_cluster=~\"$Cluster\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "hardware",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$Datasource"
          },
          "editorMode": "code",
          "expr": "max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint!=\"-\",replica!=\"-\"}[30m])) * on (node, gpu_uuid) group_left() max by (node, gpu_uuid) (last_over_time(neutree_gpu_utilization_ratio{neutree_cluster=~\"$Cluster\"}[30m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "gpu util",
          "range": false,
          "refId": "C"
        },
        {
          "expr": "max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint!=\"-\",replica!=\"-\"}[30m])) * on (node, gpu_uuid) group_left() (sum by (node, gpu_uuid) (rate(neutree_gpu_pcie_tx_bytes_total{neutree_cluster=~\"$Cluster\"}[$__rate_interval])) + sum by (node, gpu_uuid) (rate(neutree_gpu_pcie_rx_bytes_total{neutree_cluster=~\"$Cluster\"}[$__rate_interval])))",
          "refId": "D",
          "format": "table",
          "instant": true,
          "legendFormat": "pcie transfer"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$Datasource"
          },
          "editorMode": "code",
          "expr": "max by (endpoint_replica, endpoint, replica, node, node_gpu, gpu_uuid, gpu_index, product, physical_vram, vram) (last_over_time(neutree_node_gpu_allocation_info{neutree_cluster=~\"$Cluster\",endpoint!=\"-\",replica!=\"-\"}[30m])) * on (node, gpu_uuid) group_left() max by (node, gpu_uuid) (last_over_time(neutree_gpu_temperature_celsius{neutree_cluster=~\"$Cluster\"}[30m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "temperature",
          "range": false,
          "refId": "E"
        }
      ],
      "title": "GPU allocation details",
      "type": "table",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "Value #A": true,
              "Value #B": true,
              "gpu_uuid": true,
              "gpu_index": true,
              "endpoint": true,
              "replica": true
            },
            "indexByName": {
              "endpoint_replica": 0,
              "node_gpu": 1,
              "physical_vram": 2,
              "vram": 3,
              "Value #C": 4,
              "Value #D": 5,
              "product": 6,
              "architecture": 7,
              "cuda_capability": 8,
              "driver_version": 9,
