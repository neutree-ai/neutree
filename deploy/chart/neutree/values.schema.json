{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "victoria-metrics-cluster": {
      "type": "object",
      "properties": {
        "vminsert": {
          "type": "object",
          "properties": {
            "ingress": {
              "type": "object",
              "properties": {
                "hosts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "name"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
