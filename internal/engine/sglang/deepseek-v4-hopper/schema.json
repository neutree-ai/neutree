{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "SGLang DeepSeek-V4 (Hopper) Engine Configuration",
  "description": "Configuration schema for SGLang deepseek-v4-hopper ServerArgs (subset). Field names match SGLang's Python ServerArgs dataclass \u2014 Neutree calls Engine(**kwargs) directly. The K8s deploy template converts snake_case keys to kebab-case CLI flags automatically.",
  "properties": {
    "trust_remote_code": {
      "type": "boolean",
      "description": "Whether to trust remote code from Hugging Face",
      "default": false
    },
    "tokenizer_path": {
      "type": "string",
      "description": "The path of the tokenizer (defaults to model path)"
    },
    "tokenizer_mode": {
      "type": "string",
      "description": "Tokenizer mode",
      "enum": [
        "auto",
        "slow"
      ],
      "default": "auto"
    },
    "revision": {
      "type": "string",
      "description": "Specific model version (branch, tag, or commit id)"
    },
    "context_length": {
      "type": "integer",
      "description": "Model max context length (defaults to model config)",
      "minimum": 1
    },
    "chat_template": {
      "type": "string",
      "description": "Built-in chat template name or path to a chat template file"
    },
    "skip_tokenizer_init": {
      "type": "boolean",
      "description": "Skip tokenizer and detokenizer initialization",
      "default": false
    },
    "is_embedding": {
      "type": "boolean",
      "description": "Use a CausalLM as an embedding model",
      "default": false
    },
    "load_format": {
      "type": "string",
      "description": "Format of model weights to load (free-form; common: auto, pt, safetensors, dummy, etc.)",
      "default": "auto"
    },
    "dtype": {
      "type": "string",
      "description": "Data type for model weights and activations",
      "enum": [
        "auto",
        "half",
        "float16",
        "bfloat16",
        "float",
        "float32"
      ],
      "default": "auto"
    },
    "kv_cache_dtype": {
      "type": "string",
      "description": "Data type for KV cache storage",
      "enum": [
        "auto",
        "fp8_e5m2",
        "fp8_e4m3",
        "bf16",
        "bfloat16",
        "fp4_e2m1"
      ],
      "default": "auto"
    },
    "quantization": {
      "type": "string",
      "description": "Quantization method (free-form; e.g. fp8, awq, gptq, marlin, bitsandbytes, w8a8_int8, w8a8_fp8)"
    },
    "mem_fraction_static": {
      "type": "number",
      "description": "Fraction of memory used for static allocation (model weights + KV pool). Lower if OOM",
      "minimum": 0,
      "maximum": 1.0
    },
    "max_running_requests": {
      "type": "integer",
      "description": "Maximum number of concurrently running requests",
      "minimum": 1
    },
    "max_total_tokens": {
      "type": "integer",
      "description": "Maximum tokens in the memory pool (auto-calculated if unset)",
      "minimum": 1
    },
    "chunked_prefill_size": {
      "type": "integer",
      "description": "Maximum tokens per chunked-prefill chunk (-1 disables)",
      "minimum": -1,
      "default": 8192
    },
    "max_prefill_tokens": {
      "type": "integer",
      "description": "Maximum tokens in a prefill batch",
      "minimum": 1
    },
    "page_size": {
      "type": "integer",
      "description": "Page size for paged KV cache",
      "minimum": 1
    },
    "tp_size": {
      "type": "integer",
      "description": "Tensor parallel size",
      "minimum": 1,
      "default": 1
    },
    "dp_size": {
      "type": "integer",
      "description": "Data parallel size",
      "minimum": 1,
      "default": 1
    },
    "pp_size": {
      "type": "integer",
      "description": "Pipeline parallel size",
      "minimum": 1,
      "default": 1
    },
    "ep_size": {
      "type": "integer",
      "description": "Expert parallel size (MoE)",
      "minimum": 1,
      "default": 1
    },
    "enable_dp_attention": {
      "type": "boolean",
      "description": "Enable DP attention (required for some MoE configurations)",
      "default": false
    },
    "schedule_policy": {
      "type": "string",
      "description": "Schedule policy",
      "enum": [
        "lpm",
        "random",
        "fcfs",
        "dfs-weight",
        "lof",
        "priority",
        "routing-key"
      ],
      "default": "lpm"
    },
    "schedule_conservativeness": {
      "type": "number",
      "description": "Conservativeness of schedule policy",
      "minimum": 0,
      "default": 1.0
    },
    "decode_log_interval": {
      "type": "integer",
      "description": "Log interval for decode batches",
      "minimum": 1,
      "default": 40
    },
    "watchdog_timeout": {
      "type": "number",
      "description": "Watchdog timeout in seconds",
      "minimum": 1
    },
    "random_seed": {
      "type": "integer",
      "description": "Random seed for reproducibility"
    },
    "stream_interval": {
      "type": "integer",
      "description": "Streaming interval (token length per chunk)",
      "minimum": 1,
      "default": 1
    },
    "attention_backend": {
      "type": "string",
      "description": "Attention backend (free-form; e.g. flashinfer, triton, fa3, fa4, torch_native, aiter)"
    },
    "sampling_backend": {
      "type": "string",
      "description": "Sampling backend (free-form; e.g. flashinfer, pytorch)"
    },
    "grammar_backend": {
      "type": "string",
      "description": "Constrained-decoding grammar backend (free-form; e.g. xgrammar, outlines, guidance, llguidance)",
      "default": "xgrammar"
    },
    "tool_call_parser": {
      "type": "string",
      "description": "Tool call parser name (e.g. qwen25, llama3, mistral, deepseekv4)"
    },
    "reasoning_parser": {
      "type": "string",
      "description": "Reasoning content parser name (e.g. qwen3, deepseek-r1, deepseek-v4)"
    },
    "speculative_algorithm": {
      "type": "string",
      "description": "Speculative decoding algorithm",
      "enum": [
        "EAGLE",
        "EAGLE3",
        "NEXTN",
        "STANDALONE",
        "NGRAM"
      ]
    },
    "speculative_num_steps": {
      "type": "integer",
      "description": "Speculative decoding step count",
      "minimum": 1
    },
    "speculative_eagle_topk": {
      "type": "integer",
      "description": "EAGLE topk",
      "minimum": 1
    },
    "speculative_num_draft_tokens": {
      "type": "integer",
      "description": "Number of speculative draft tokens",
      "minimum": 1
    },
    "speculative_token_map": {
      "type": "string",
      "description": "Path to speculative token map"
    },
    "speculative_draft_model_path": {
      "type": "string",
      "description": "Path to the speculative draft model"
    },
    "lora_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of LoRA adapter paths"
    },
    "max_loras_per_batch": {
      "type": "integer",
      "description": "Maximum number of LoRA adapters in a running batch",
      "minimum": 1
    },
    "log_level": {
      "type": "string",
      "description": "Logger level",
      "default": "info"
    },
    "log_level_http": {
      "type": "string",
      "description": "HTTP server log level (defaults to log_level)"
    },
    "log_requests": {
      "type": "boolean",
      "description": "Log inputs/outputs of all requests",
      "default": false
    },
    "show_time_cost": {
      "type": "boolean",
      "description": "Show time cost of custom marks in logs",
      "default": false
    },
    "enable_metrics": {
      "type": "boolean",
      "description": "Enable Prometheus metrics endpoint",
      "default": false
    },
    "enable_cache_report": {
      "type": "boolean",
      "description": "Return cached_tokens in usage.prompt_tokens_details",
      "default": false
    },
    "disable_radix_cache": {
      "type": "boolean",
      "description": "Disable RadixAttention prefix caching",
      "default": false
    },
    "disable_cuda_graph": {
      "type": "boolean",
      "description": "Disable CUDA graph (fall back to eager)",
      "default": false
    },
    "disable_cuda_graph_padding": {
      "type": "boolean",
      "description": "Disable CUDA graph when padding is detected",
      "default": false
    },
    "enable_torch_compile": {
      "type": "boolean",
      "description": "Optimise model with torch.compile (experimental)",
      "default": false
    },
    "enable_p2p_check": {
      "type": "boolean",
      "description": "Enable P2P check for GPU access",
      "default": false
    },
    "enable_mixed_chunk": {
      "type": "boolean",
      "description": "Enable mixed-chunk scheduling for prefill",
      "default": false
    },
    "enable_two_batch_overlap": {
      "type": "boolean",
      "description": "Enable two-batch overlap (perf optimisation)",
      "default": false
    },
    "disaggregation_mode": {
      "type": "string",
      "description": "Disaggregation role for P/D split",
      "enum": [
        "null",
        "prefill",
        "decode"
      ],
      "default": "null"
    },
    "disaggregation_decode_dp": {
      "type": "integer",
      "description": "Decode DP size for disaggregation",
      "minimum": 1
    },
    "disaggregation_decode_tp": {
      "type": "integer",
      "description": "Decode TP size for disaggregation",
      "minimum": 1
    },
    "disaggregation_prefill_pp": {
      "type": "integer",
      "description": "Prefill PP size for disaggregation",
      "minimum": 1,
      "default": 1
    },
    "disaggregation_decode_enable_fake_auto": {
      "type": "boolean",
      "description": "Enable fake auto-decode for disaggregation testing",
      "default": false
    },
    "moe_a2a_backend": {
      "type": "string",
      "description": "MoE all-to-all backend (free-form; e.g. deepep, mooncake, ascend)"
    },
    "moe_runner_backend": {
      "type": "string",
      "description": "MoE runner backend (free-form; default: auto)",
      "default": "auto"
    },
    "enable_piecewise_cuda_graph": {
      "type": "boolean",
      "description": "Enable piecewise CUDA graph capture",
      "default": false
    },
    "speculative_ngram_branch_length": {
      "type": "integer",
      "description": "NGRAM speculative branch length",
      "minimum": 1,
      "default": 18
    },
    "speculative_ngram_max_match_window_size": {
      "type": "integer",
      "description": "NGRAM max match window size",
      "minimum": 1,
      "default": 12
    },
    "speculative_ngram_min_match_window_size": {
      "type": "integer",
      "description": "NGRAM min match window size",
      "minimum": 1,
      "default": 1
    },
    "mm_max_concurrent_calls": {
      "type": "integer",
      "description": "Max concurrent multimodal preprocessing calls",
      "minimum": 1,
      "default": 32
    },
    "mm_per_request_timeout": {
      "type": "number",
      "description": "Per-request multimodal preprocessing timeout (seconds)",
      "minimum": 0,
      "default": 10.0
    },
    "enable_return_indexer_topk": {
      "type": "boolean",
      "description": "Return indexer topk metadata",
      "default": false
    },
    "hierarchical_sparse_attention_extra_config": {
      "type": "string",
      "description": "Hierarchical sparse-attention extra config (JSON string)"
    },
    "stream_output": {
      "type": "boolean",
      "description": "Enable streaming output mode in scheduler",
      "default": false
    },
    "disable_hicache_numa_detect": {
      "type": "boolean",
      "description": "Disable hierarchical-cache NUMA topology detection",
      "default": false
    }
  },
  "additionalProperties": false
}
